# ─── Servidor ──────────────────────────────────────────────────────────────────
# Puerto en el que escucha el servidor HTTP
PORT=3000

# Entorno de ejecución. Afecta al rate limit, detalles de error y comportamiento de tests.
# Valores: development | production | test
NODE_ENV=development

# ─── Base de datos ─────────────────────────────────────────────────────────────
# URI de conexión a MongoDB. En Docker Compose el host es el nombre del servicio ("mongo").
MONGODB_URI=mongodb://127.0.0.1:27017/bildyapp_dev

# ─── Autenticación JWT ─────────────────────────────────────────────────────────
# Secreto para firmar los access tokens (válidos 15 min). Usa un string aleatorio largo.
JWT_ACCESS_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

# Secreto para firmar los refresh tokens (válidos 7 días). Debe ser diferente al de arriba.
JWT_REFRESH_SECRET=cambia_este_secreto_refresh_por_otro_distinto

# ─── CORS y Socket.IO ──────────────────────────────────────────────────────────
# Origen(es) permitidos para peticiones CORS y conexiones Socket.IO.
# En producción pon la URL exacta del frontend. En desarrollo puedes usar *.
CORS_ORIGIN=http://localhost:5173

# ─── Slack (logging de errores 5XX) ───────────────────────────────────────────
# URL del Incoming Webhook de Slack. Si está vacío, los errores solo se loguean en consola.
# Crea uno en: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Email (Nodemailer SMTP) ───────────────────────────────────────────────────
# Usa Mailtrap (https://mailtrap.io) en desarrollo para no enviar emails reales.
# Si alguna de estas variables está vacía, los emails se simulan en consola.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=tu_usuario_de_mailtrap
SMTP_PASS=tu_password_de_mailtrap
SMTP_FROM=BildyApp <no-reply@bildyapp.com>

# ─── Almacenamiento en la nube (Cloudinary) ───────────────────────────────────
# Proveedor de storage. Actualmente solo "cloudinary" está implementado.
STORAGE_PROVIDER=cloudinary

# URL de Cloudinary con credenciales embebidas.
# Formato: cloudinary://api_key:api_secret@cloud_name
# Encuéntrala en: https://console.cloudinary.com → Dashboard
CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@mi-cloud-name
